# Ops Voice Co-Pilot — copy to .env and set values
# GCP (required for Vertex AI Live API and Cloud Logging)
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
VERTEX_AI_LOCATION=europe-west1

# Optional: path to service account JSON (default: Application Default Credentials)
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/key.json

# Gemini Live model (Vertex)
GEMINI_LIVE_MODEL=gemini-live-2.5-flash-native-audio

# Server
PORT=8080
LOG_LEVEL=INFO
